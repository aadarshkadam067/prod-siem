# ============================================================
# prod-siem — Environment Configuration
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================

# Get a free key at: https://console.groq.com/keys
# Leave blank to run without AI triage (everything else still works)
GROQ_API_KEY=your_groq_key_here

# Elasticsearch (matches docker-compose.yml defaults)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379/0

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# TheHive (optional — only needed with ./setup.sh --full)
THEHIVE_URL=http://localhost:9000
THEHIVE_API_KEY=your_thehive_key_here

# Cortex (optional — only needed with ./setup.sh --full)
CORTEX_URL=http://localhost:9001
CORTEX_API_KEY=your_cortex_key_here
